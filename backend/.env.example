MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/nexusmeet
PORT=8000
JWT_SECRET=change_this_to_something_random
JWT_EXPIRES_IN=7d
CORS_ORIGINS=http://localhost:3000

# optional — Redis for shared room state (falls back to in-memory without it)
# REDIS_URL=redis://localhost:6379

# optional — TURN server for NAT traversal behind symmetric NATs/firewalls
# Supports comma-separated URLs for UDP+TCP on one set of credentials:
# TURN_URL=turn:relay.example.com:3478,turns:relay.example.com:5349
# TURN_USERNAME=user
# TURN_CREDENTIAL=pass

# optional — second TURN server (e.g. a different provider or TCP-only fallback)
# TURN_URL_2=turn:fallback.example.com:3478?transport=tcp
# TURN_USERNAME_2=user2
# TURN_CREDENTIAL_2=pass2
